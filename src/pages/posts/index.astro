---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteSections } from "../../site";

const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => /^(https?:)?\/\//.test(path) ? path : `${base}${path.replace(/^\/+/, "")}`;
---

<BaseLayout title="الأخبار | Arab Tech Trends">
  <section class="page-head">
    <p class="eyebrow">الأرشيف</p>
    <h1>كل الأخبار والمقالات</h1>
  </section>
  <section class="category-bar" aria-label="الأقسام">
    {siteSections.map((category) => <a href={withBase("/posts/")}>{category}</a>)}
  </section>
  <div class="post-list">
    {posts.map((post) => (
      <article>
        {post.data.image ? <img src={withBase(post.data.image)} alt="" loading="lazy" /> : <span class="media-fallback">{post.data.category.slice(0, 2)}</span>}
        <div>
          <p>{post.data.category}</p>
          <h2><a href={withBase(`/posts/${post.slug}/`)}>{post.data.title}</a></h2>
          <span>{post.data.pubDate.toLocaleDateString("ar-EG")}</span>
        </div>
      </article>
    ))}
  </div>
</BaseLayout>
