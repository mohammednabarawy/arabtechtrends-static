---
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { postsPerPage } from "../../site";
import { getPostImage, getPostExcerpt } from "../../utils/posts";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  return paginate(posts, { pageSize: postsPerPage });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${base}${path.replace(/^\/+/, "")}`;
---

<BaseLayout title="الأرشيف | عرب تك" canonicalPath={page.url.current}>
  <Breadcrumbs
    items={[
      { label: "الرئيسية", href: "/" },
      { label: "الأرشيف" }
    ]}
  />
  <section class="page-head">
    <p class="eyebrow">الأرشيف</p>
    <h1>كل الأخبار والمقالات</h1>
    <p class="page-meta">صفحة {page.currentPage} من {page.lastPage} — {page.total} مقال</p>
  </section>

  <div class="post-list">
    {page.data.map((post) => {
      const img = getPostImage(post);
      return (
        <article class="post-list-item">
          <a class="post-list-item__media" href={withBase(`/posts/${post.slug}/`)} tabindex="-1" aria-hidden="true">
            {img ? (
              <img src={img.startsWith("http") ? img : withBase(img)} alt={post.data.title} loading="lazy" decoding="async" />
            ) : (
              <span class="media-fallback">{post.data.category.slice(0, 2)}</span>
            )}
          </a>
          <div>
            <p>{post.data.category}</p>
            <h2><a href={withBase(`/posts/${post.slug}/`)}>{post.data.title}</a></h2>
            <p class="post-list-item__excerpt">{getPostExcerpt(post, 180)}</p>
            <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString("ar-EG")}</time>
          </div>
        </article>
      );
    })}
  </div>

  {page.lastPage > 1 && (
    <nav class="pagination" aria-label="تصفح الصفحات">
      {page.url.prev && <a href={page.url.prev}>السابق</a>}
      <span>صفحة {page.currentPage} / {page.lastPage}</span>
      {page.url.next && <a href={page.url.next}>التالي</a>}
    </nav>
  )}
</BaseLayout>
