---
import { getCollection, render } from "astro:content";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteName, siteUrl } from "../../site";
import { absoluteUrl, getPostImage, getRelatedPosts } from "../../utils/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post, allPosts: posts } }));
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => /^(https?:)?\/\//.test(path) ? path : `${base}${path.replace(/^\/+/, "")}`;
const image = getPostImage(post);
const related = getRelatedPosts(post, allPosts, 4);
const articleUrl = absoluteUrl(`/posts/${post.slug}/`, siteUrl);

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  headline: post.data.title,
  description: post.data.description,
  image: image ? [image.startsWith("http") ? image : absoluteUrl(image, siteUrl)] : undefined,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    "@type": "Organization",
    name: post.data.author
  },
  publisher: {
    "@type": "Organization",
    name: siteName,
    logo: {
      "@type": "ImageObject",
      url: absoluteUrl("/uploads/arabtech-logo.png", siteUrl)
    }
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": articleUrl
  },
  inLanguage: "ar",
  articleSection: post.data.category
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "الرئيسية", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "الأرشيف", item: absoluteUrl("/posts/", siteUrl) },
    { "@type": "ListItem", position: 3, name: post.data.title, item: articleUrl }
  ]
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={image}
  canonicalPath={`/posts/${post.slug}/`}
  type="article"
  publishedTime={post.data.pubDate.toISOString()}
  modifiedTime={(post.data.updatedDate ?? post.data.pubDate).toISOString()}
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
  showCategoryBar={false}
>
  <article class="article">
    <Breadcrumbs
      items={[
        { label: "الرئيسية", href: "/" },
        { label: "الأرشيف", href: "/posts/" },
        { label: post.data.title }
      ]}
    />
    <p class="eyebrow">{post.data.category}</p>
    <h1>{post.data.title}</h1>
    <div class="article-meta">
      <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString("ar-EG")}</time>
      <span>{post.data.author}</span>
      {post.data.updatedDate && (
        <span>تحديث: {post.data.updatedDate.toLocaleDateString("ar-EG")}</span>
      )}
    </div>
    {image && <img class="cover" src={withBase(image)} alt={post.data.title} loading="eager" decoding="async" />}
    <div class="article-body" data-pagefind-body>
      <Content />
    </div>
    {post.data.tags.length > 0 && (
      <ul class="tag-list">
        {post.data.tags.map((tag) => (
          <li><span>{tag}</span></li>
        ))}
      </ul>
    )}
  </article>

  {related.length > 0 && (
    <section class="related-posts">
      <div class="section-head">
        <h2>مقالات ذات صلة</h2>
      </div>
      <div class="post-grid compact-grid">
        {related.map((item) => <PostCard post={item} compact />)}
      </div>
    </section>
  )}
</BaseLayout>
