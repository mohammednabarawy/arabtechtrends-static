---
import { getCollection } from "astro:content";
import PostCard from "../components/PostCard.astro";
import VideoCard from "../components/VideoCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { pillarGuides } from "../guides";
import { categories, socialLinks, telegramChannelUrl } from "../site";
import { getPostImage, sortPostsForHomepage, withBase } from "../utils/posts";
import { getTopPostsMeta, resolveTopPosts } from "../utils/topPosts";
import { filterYouTubePosts } from "../utils/youtubePosts";

const allPosts = sortPostsForHomepage(await getCollection("posts", ({ data }) => !data.draft));
const topPosts = resolveTopPosts(allPosts, 6);
const topMeta = getTopPostsMeta();
const youtubePosts = filterYouTubePosts(allPosts).slice(0, 6);
const youtubeChannelUrl = socialLinks.find((l) => l.label === "YouTube")?.href;
const posts = allPosts.slice(0, 120);
const guidePosts = allPosts.filter((p) => /شرح|دليل|كيفية|أفضل/i.test(p.data.title)).slice(0, 4);

const [featured, ...rest] = posts;
const sidePosts = rest.slice(0, 4);
const latest = rest.slice(4, 10);
const usedPostIds = new Set([
  featured?.id,
  ...sidePosts.map((p) => p.id),
  ...latest.map((p) => p.id),
  ...topPosts.map((p) => p.id),
  ...youtubePosts.map((p) => p.id)
].filter(Boolean));

const pickSectionPosts = (categorySlug: string) => {
  const category = categories.find((c) => c.slug === categorySlug);
  if (!category) return [];
  const picked = [];
  for (const post of posts) {
    if (usedPostIds.has(post.id)) continue;
    const text = `${post.data.title} ${post.data.category}`.toLowerCase();
    if (!category.keywords.some((k) => text.includes(k.toLowerCase()))) continue;
    picked.push(post);
    usedPostIds.add(post.id);
    if (picked.length === 4) break;
  }
  return picked;
};

const sectionGroups = [
  { title: "هواتف وأندرويد", slug: "phones", posts: pickSectionPosts("phones") },
  { title: "آيفون وآبل", slug: "iphone", posts: pickSectionPosts("iphone") },
  { title: "تطبيقات وشروحات", slug: "apps", posts: pickSectionPosts("apps") }
].filter((g) => g.posts.length);

const tickerPosts = posts.slice(0, 8);

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const featuredImage = featured ? getPostImage(featured) : undefined;
---

<BaseLayout title="عرب تك | التقنية بين يديك" image={featuredImage}>
  <section class="ticker" aria-label="عناوين سريعة">
    <strong>عاجل</strong>
    <div class="ticker__track">
      {tickerPosts.map((post) => (
        <a class="ticker__link" href={withBase(`/posts/${post.slug}/`, base)}>
          {post.data.title}
        </a>
      ))}
    </div>
  </section>

  <section class="subscribe-strip" aria-label="اشترك في التحديثات">
    <div>
      <strong>لا تفوّت أخبار التقنية</strong>
      <p>اشترك عبر RSS أو تابعنا على الشبكات الاجتماعية</p>
    </div>
    <div class="subscribe-strip__actions">
      <a class="btn-primary" href={withBase("/feed.xml", base)}>RSS</a>
      {telegramChannelUrl && (
        <a class="btn-outline" href={telegramChannelUrl} rel="noopener noreferrer">تيليجرام</a>
      )}
      <a class="btn-outline" href={withBase("/guides/", base)}>أدلة شاملة</a>
    </div>
  </section>

  <section class="hero">
    {featured && (
      <a class="lead-card" href={withBase(`/posts/${featured.slug}/`, base)}>
        {(() => {
          const img = getPostImage(featured);
          return img ? (
            <img
              src={withBase(img, base)}
              alt={featured.data.title}
              loading="eager"
              fetchpriority="high"
              decoding="async"
              width="1200"
              height="675"
            />
          ) : (
            <span class="media-fallback">ATT</span>
          );
        })()}
        <em>{featured.data.category}</em>
        <strong>{featured.data.title}</strong>
        <small>{featured.data.pubDate.toLocaleDateString("ar-EG")}</small>
      </a>
    )}
    <div class="hero-stack">
      {sidePosts.map((post) => {
        const img = getPostImage(post);
        return (
          <a href={withBase(`/posts/${post.slug}/`, base)}>
            {img ? (
              <img src={withBase(img, base)} alt={post.data.title} loading="lazy" decoding="async" />
            ) : (
              <span class="media-fallback">{post.data.category.slice(0, 2)}</span>
            )}
            <span>{post.data.category}</span>
            <strong>{post.data.title}</strong>
          </a>
        );
      })}
    </div>
  </section>

  {topPosts.length > 0 && (
    <section class="section-block">
      <div class="section-head">
        <h2>الأكثر قراءة</h2>
        <small class="page-meta">آخر تحديث: {topMeta.updated}</small>
      </div>
      <div class="post-grid compact-grid">
        {topPosts.map((post) => <PostCard post={post} compact />)}
      </div>
    </section>
  )}

  {youtubePosts.length > 0 && (
    <section class="section-block section-block--videos">
      <div class="section-head">
        <h2>شروحات فيديو</h2>
        <div class="section-head__links">
          <a href={withBase("/videos/", base)}>كل الفيديوهات</a>
          {youtubeChannelUrl && (
            <a class="section-head__link-alt" href={youtubeChannelUrl} rel="noopener noreferrer">يوتيوب</a>
          )}
        </div>
      </div>
      <div class="post-grid compact-grid">
        {youtubePosts.map((post) => <VideoCard post={post} compact />)}
      </div>
    </section>
  )}

  <section class="section-block">
    <div class="section-head">
      <h2>أدلة شاملة</h2>
      <a href={withBase("/guides/", base)}>كل الأدلة</a>
    </div>
    <div class="pillar-grid pillar-grid--compact">
      {pillarGuides.map((guide) => (
        <a class="pillar-card" href={withBase(`/guides/${guide.slug}/`, base)}>
          <h3>{guide.title}</h3>
          <p>{guide.description}</p>
        </a>
      ))}
    </div>
  </section>

  {guidePosts.length > 0 && (
    <section class="section-block">
      <div class="section-head">
        <h2>شروحات مميزة</h2>
        <a href={withBase("/category/guides/", base)}>المزيد</a>
      </div>
      <div class="post-grid compact-grid">
        {guidePosts.map((post) => <PostCard post={post} compact />)}
      </div>
    </section>
  )}

  <section class="section-head">
    <h2>مقالات حديثة</h2>
    <a href={withBase("/posts/", base)}>كل المقالات</a>
  </section>

  <div class="post-grid">
    {latest.map((post) => <PostCard post={post} />)}
  </div>

  {sectionGroups.map((group) => (
    <section class="section-block">
      <div class="section-head">
        <h2>{group.title}</h2>
        <a href={withBase(`/category/${group.slug}/`, base)}>المزيد</a>
      </div>
      <div class="post-grid compact-grid">
        {group.posts.map((post) => <PostCard post={post} compact />)}
      </div>
    </section>
  ))}
</BaseLayout>
