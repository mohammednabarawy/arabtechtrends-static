---
import { getCollection } from "astro:content";
import PostCard from "../components/PostCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { categories } from "../site";
import { filterPostsByCategory, getPostImage, sortPosts } from "../utils/posts";

const allPosts = sortPosts(await getCollection("posts", ({ data }) => !data.draft));
const posts = allPosts.slice(0, 120);

const [featured, ...rest] = posts;
const sidePosts = rest.slice(0, 4);
const latest = rest.slice(4, 10);
const usedPostIds = new Set([featured?.id, ...sidePosts.map((p) => p.id), ...latest.map((p) => p.id)].filter(Boolean));

const pickSectionPosts = (categorySlug: string) => {
  const category = categories.find((c) => c.slug === categorySlug);
  if (!category) return [];
  const picked = [];
  for (const post of posts) {
    if (usedPostIds.has(post.id)) continue;
    const text = `${post.data.title} ${post.data.category}`.toLowerCase();
    if (!category.keywords.some((k) => text.includes(k.toLowerCase()))) continue;
    picked.push(post);
    usedPostIds.add(post.id);
    if (picked.length === 4) break;
  }
  return picked;
};

const sectionGroups = [
  { title: "هواتف وأندرويد", slug: "phones", posts: pickSectionPosts("phones") },
  { title: "آيفون وآبل", slug: "iphone", posts: pickSectionPosts("iphone") },
  { title: "تطبيقات وشروحات", slug: "apps", posts: pickSectionPosts("apps") }
].filter((g) => g.posts.length);

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => path.startsWith("http") ? path : `${base}${path.replace(/^\/+/, "")}`;
const featuredImage = featured ? getPostImage(featured) : undefined;
---

<BaseLayout title="عرب تك | التقنية بين يديك" image={featuredImage}>
  <section class="ticker">
    <strong>آخر الأخبار</strong>
    {featured && (
      <a class="ticker__link" href={withBase(`/posts/${featured.slug}/`)}>
        {featured.data.title}
      </a>
    )}
  </section>

  <section class="hero">
    {featured && (
      <a class="lead-card" href={withBase(`/posts/${featured.slug}/`)}>
        {(() => {
          const img = getPostImage(featured);
          return img ? (
            <img src={withBase(img)} alt={featured.data.title} loading="eager" decoding="async" />
          ) : (
            <span class="media-fallback">ATT</span>
          );
        })()}
        <em>{featured.data.category}</em>
        <strong>{featured.data.title}</strong>
        <small>{featured.data.pubDate.toLocaleDateString("ar-EG")}</small>
      </a>
    )}
    <div class="hero-stack">
      {sidePosts.map((post) => {
        const img = getPostImage(post);
        return (
          <a href={withBase(`/posts/${post.slug}/`)}>
            {img ? (
              <img src={withBase(img)} alt={post.data.title} loading="lazy" decoding="async" />
            ) : (
              <span class="media-fallback">{post.data.category.slice(0, 2)}</span>
            )}
            <span>{post.data.category}</span>
            <strong>{post.data.title}</strong>
          </a>
        );
      })}
    </div>
  </section>

  <section class="section-head">
    <h2>آخر الأخبار</h2>
    <a href={withBase("/posts/")}>كل المقالات</a>
  </section>

  <div class="post-grid">
    {latest.map((post) => <PostCard post={post} />)}
  </div>

  {sectionGroups.map((group) => (
    <section class="section-block">
      <div class="section-head">
        <h2>{group.title}</h2>
        <a href={withBase(`/category/${group.slug}/`)}>المزيد</a>
      </div>
      <div class="post-grid compact-grid">
        {group.posts.map((post) => <PostCard post={post} compact />)}
      </div>
    </section>
  ))}
</BaseLayout>
