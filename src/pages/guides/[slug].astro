---
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { pillarGuides } from "../../guides";
import { categories, siteUrl } from "../../site";
import { absoluteUrl, filterPostsByCategory, sortPosts, withBase } from "../../utils/posts";

export const getStaticPaths = (() =>
  pillarGuides.map((guide) => ({ params: { slug: guide.slug }, props: { guide } }))) satisfies GetStaticPaths;

const { guide } = Astro.props;
const allPosts = sortPosts(await getCollection("posts", ({ data }) => !data.draft));
const category = categories.find((c) => c.slug === guide.categorySlug);
const related = category ? filterPostsByCategory(allPosts, category).slice(0, 12) : [];
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const pageUrl = absoluteUrl(`/guides/${guide.slug}/`, siteUrl);

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: guide.faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer }
  }))
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "الرئيسية", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "أدلة شاملة", item: absoluteUrl("/guides/", siteUrl) },
    { "@type": "ListItem", position: 3, name: guide.title, item: pageUrl }
  ]
};
---

<BaseLayout
  title={`${guide.title} | عرب تك`}
  description={guide.description}
  canonicalPath={`/guides/${guide.slug}/`}
  jsonLd={[faqJsonLd, breadcrumbJsonLd]}
>
  <Breadcrumbs
    items={[
      { label: "الرئيسية", href: "/" },
      { label: "أدلة شاملة", href: "/guides/" },
      { label: guide.title }
    ]}
  />

  <article class="article guide-panel">
    <div class="guide-hero">
      <img src={guide.image} alt={guide.title} class="guide-hero-image" />
      <div class="guide-hero-content">
        <div class="guide-hero-header">
          <div class="guide-hero-icon" set:html={guide.icon} />
          <p class="eyebrow">دليل شامل</p>
        </div>
        <h1>{guide.title}</h1>
        <p class="guide-desc">{guide.description}</p>
        {category && (
          <a class="guide-category-link" href={withBase(`/category/${category.slug}/`, base)}>تصفّح جميع مقالات قسم {category.label} ←</a>
        )}
      </div>
    </div>

    <div class="guide-introductory-content" set:html={guide.content} />

    <div class="guide-faq-section">
      <h2>أسئلة شائعة</h2>
      <div class="faq-accordion">
        {guide.faqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-summary">
              {faq.question}
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="faq-icon"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <div class="faq-content">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </article>

  <style>
    .guide-hero {
      display: flex;
      flex-direction: column;
      background: var(--surface-1);
      border-radius: 16px;
      margin-bottom: 2rem;
      border: 1px solid var(--border);
      overflow: hidden;
    }
    .guide-hero-image {
      width: 100%;
      height: 300px;
      object-fit: cover;
      border-bottom: 1px solid var(--border);
    }
    .guide-hero-content {
      padding: 2.5rem;
    }
    .guide-hero-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
    }
    @media (min-width: 768px) {
      .guide-hero-image {
        height: 400px;
      }
      .guide-hero-content {
        padding: 3.5rem;
      }
    }
    .guide-hero-icon {
      width: 56px;
      height: 56px;
      flex-shrink: 0;
      background: var(--surface-2);
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--primary);
    }
    .guide-hero-icon :global(svg) {
      width: 28px;
      height: 28px;
    }
    .guide-hero h1 {
      margin: 0.5rem 0 1rem;
      font-size: 2.5rem;
    }
    .guide-desc {
      font-size: 1.2rem;
      line-height: 1.6;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
    }
    .guide-category-link {
      display: inline-block;
      padding: 0.75rem 1.5rem;
      background: var(--primary);
      color: white;
      text-decoration: none;
      border-radius: 8px;
      font-weight: bold;
      transition: opacity 0.2s;
    }
    .guide-category-link:hover {
      opacity: 0.9;
    }

    .guide-introductory-content {
      font-size: 1.15rem;
      line-height: 1.8;
      color: var(--text);
      margin-bottom: 3rem;
    }
    .guide-introductory-content :global(p) {
      margin-bottom: 1.5rem;
    }
    
    .guide-faq-section {
      margin-bottom: 4rem;
    }
    .faq-accordion {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-top: 1.5rem;
    }
    .faq-item {
      background: var(--surface-1);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
    }
    .faq-summary {
      padding: 1.5rem;
      font-weight: 600;
      font-size: 1.1rem;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      list-style: none;
    }
    .faq-summary::-webkit-details-marker {
      display: none;
    }
    .faq-icon {
      transition: transform 0.3s ease;
      color: var(--primary);
    }
    details[open] .faq-icon {
      transform: rotate(180deg);
    }
    .faq-content {
      padding: 0 1.5rem 1.5rem;
      color: var(--text-muted);
      line-height: 1.6;
    }
    .faq-content p {
      margin: 0;
    }
  </style>

  {related.length > 0 && (
    <section class="related-posts">
      <div class="section-head">
        <h2>مقالات في هذا الموضوع</h2>
        {category && <a href={withBase(`/category/${category.slug}/`, base)}>المزيد</a>}
      </div>
      <div class="post-grid compact-grid">
        {related.map((post) => <PostCard post={post} compact />)}
      </div>
    </section>
  )}
</BaseLayout>
