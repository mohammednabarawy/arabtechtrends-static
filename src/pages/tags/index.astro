---
import { getCollection } from "astro:content";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { TagEntry } from "../../utils/posts";
import { buildTagIndex, withBase } from "../../utils/posts";

const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const tags = buildTagIndex(allPosts).slice(0, 120);
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="الوسوم | عرب تك" canonicalPath="/tags/">
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الوسوم" }]} />
  <section class="page-head">
    <p class="eyebrow">فهرس</p>
    <h1>وسوم المواضيع</h1>
    <p class="page-meta">{tags.length} وسم مفيد — تصفّح الشروحات حسب المجال</p>
  </section>

  <ul class="tag-cloud">
    {tags.map((tag: TagEntry) => (
      <li>
        <a href={withBase(`/tag/${tag.slug}/`, base)}>
          {tag.label}
          <small>{tag.count}</small>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

