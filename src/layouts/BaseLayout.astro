---
import "../styles/global.css";

const {
  title = "Arab Tech Trends",
  description = "Technology news, guides, and trends for Arabic readers."
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => /^(https?:)?\/\//.test(path) ? path : `${base}${path.replace(/^\/+/, "")}`;
const today = new Intl.DateTimeFormat("ar-EG", { dateStyle: "full" }).format(new Date());
---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="top-strip">
      <span>{today}</span>
      <span>التقنية بين يديك</span>
    </div>
    <header class="site-header">
      <a class="brand" href={withBase("/")} aria-label="عرب تك">
        <img src={withBase("/uploads/arabtech-logo.png")} alt="" />
        <span>
          <strong>عرب تك</strong>
          <small>Arab Tech Trends</small>
        </span>
      </a>
      <nav aria-label="Primary navigation">
        <a href={withBase("/")}>الرئيسية</a>
        <a href={withBase("/posts/")}>الأخبار</a>
        <a href={withBase("/posts/")}>هواتف</a>
        <a href={withBase("/posts/")}>تطبيقات</a>
        <a href={withBase("/admin/")}>إدارة المحتوى</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>Arab Tech Trends - أخبار التقنية بواجهة سريعة ومجانية.</p>
    </footer>
  </body>
</html>
