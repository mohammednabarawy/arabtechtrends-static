---
import "../styles/global.css";
import CategoryBar from "../components/CategoryBar.astro";
import SeoHead from "../components/SeoHead.astro";
import { categories, footerAbout, siteName, siteTagline, siteUrl, socialLinks } from "../site";
import { withBase } from "../utils/posts";

const {
  title = "Arab Tech Trends",
  description,
  image,
  canonicalPath,
  type = "website",
  publishedTime,
  modifiedTime,
  jsonLd,
  showCategoryBar = true
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const today = new Intl.DateTimeFormat("ar-EG", { dateStyle: "full" }).format(new Date());
---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <SeoHead
      title={title}
      description={description}
      image={image}
      canonicalPath={canonicalPath}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      jsonLd={jsonLd}
    />
  </head>
  <body>
    <div class="top-strip">
      <span>{today}</span>
      <span>{siteTagline}</span>
    </div>
    <header class="site-header">
      <a class="brand" href={withBase("/", base)} aria-label={siteName}>
        <img src={withBase("/uploads/arabtech-logo.png", base)} alt={siteName} width="58" height="58" />
        <span>
          <strong>{siteName}</strong>
          <small>Arab Tech Trends</small>
        </span>
      </a>
      <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="فتح القائمة">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <nav id="site-nav" class="site-nav" aria-label="التنقل الرئيسي">
        <a href={withBase("/", base)}>الرئيسية</a>
        {categories.map((category) => (
          <a href={withBase(`/category/${category.slug}/`, base)}>{category.label}</a>
        ))}
        <a href={withBase("/guides/", base)}>أدلة</a>
        <a href={withBase("/posts/", base)}>الأرشيف</a>
        <a href={withBase("/tags/", base)}>الوسوم</a>
        <a href={withBase("/search/", base)}>بحث</a>
        <a href={withBase("/about/", base)}>من نحن</a>
      </nav>
    </header>
    <main>
      {showCategoryBar && <CategoryBar />}
      <slot />
    </main>
    <div class="nav-backdrop" hidden aria-hidden="true"></div>
    <footer class="site-footer">
      <div class="footer-grid">
        <section class="footer-about" aria-labelledby="footer-about-title">
          <h2 id="footer-about-title">معلومات عن الموقع</h2>
          <p>{footerAbout}</p>
          <p class="footer-since">منذ 2012 — {siteTagline}</p>
        </section>
        <section class="footer-sections" aria-labelledby="footer-sections-title">
          <h2 id="footer-sections-title">الأقسام</h2>
          <div>
            {categories.map((category) => (
              <a href={withBase(`/category/${category.slug}/`, base)}>{category.label}</a>
            ))}
            <a href={withBase("/guides/", base)}>أدلة شاملة</a>
            <a href={withBase("/about/", base)}>من نحن</a>
          </div>
        </section>
        <section class="footer-social" aria-labelledby="footer-social-title">
          <h2 id="footer-social-title">تابعنا</h2>
          <div>
            {socialLinks.map((link) => (
              <a href={link.href.startsWith("http") ? link.href : withBase(link.href, base)} rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}>
                {link.label}
              </a>
            ))}
          </div>
        </section>
      </div>
      <p class="copyright">© {new Date().getFullYear()} {siteName} — جميع الحقوق محفوظة</p>
    </footer>
    <script is:inline>
      const toggle = document.querySelector(".nav-toggle");
      const nav = document.querySelector("#site-nav");
      const backdrop = document.querySelector(".nav-backdrop");

      const setNavOpen = (open) => {
        nav?.classList.toggle("is-open", open);
        document.body.classList.toggle("nav-open", open);
        toggle?.setAttribute("aria-expanded", String(open));
        if (backdrop) backdrop.hidden = !open;
      };

      toggle?.addEventListener("click", () => {
        setNavOpen(!nav?.classList.contains("is-open"));
      });

      backdrop?.addEventListener("click", () => setNavOpen(false));

      nav?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => setNavOpen(false));
      });
    </script>
  </body>
</html>
