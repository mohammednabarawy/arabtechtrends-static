---
import "../styles/global.css";
import { footerAbout, siteSections, socialLinks } from "../site";

const {
  title = "Arab Tech Trends",
  description = "Technology news, guides, and trends for Arabic readers."
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => /^(https?:)?\/\//.test(path) ? path : `${base}${path.replace(/^\/+/, "")}`;
const today = new Intl.DateTimeFormat("ar-EG", { dateStyle: "full" }).format(new Date());
---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="top-strip">
      <span>{today}</span>
      <span>التقنية بين يديك</span>
    </div>
    <header class="site-header">
      <a class="brand" href={withBase("/")} aria-label="عرب تك">
        <img src={withBase("/uploads/arabtech-logo.png")} alt="" />
        <span>
          <strong>عرب تك</strong>
          <small>Arab Tech Trends</small>
        </span>
      </a>
      <nav aria-label="Primary navigation">
        <a href={withBase("/")}>الرئيسية</a>
        {siteSections.map((section) => <a href={withBase("/posts/")}>{section}</a>)}
        <a href={withBase("/admin/")}>إدارة المحتوى</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-grid">
        <section class="footer-about" aria-labelledby="footer-about-title">
          <h2 id="footer-about-title">معلومات عن الموقع</h2>
          <p>{footerAbout}</p>
        </section>
        <section class="footer-sections" aria-labelledby="footer-sections-title">
          <h2 id="footer-sections-title">الأقسام</h2>
          <div>
            {siteSections.map((section) => <a href={withBase("/posts/")}>{section}</a>)}
          </div>
        </section>
        <section class="footer-social" aria-labelledby="footer-social-title">
          <h2 id="footer-social-title">تابعنا</h2>
          <div>
            {socialLinks.map((link) => <a href={withBase(link.href)}>{link.label}</a>)}
          </div>
        </section>
      </div>
      <p class="copyright">© حقوق النشر 2026، جميع الحقوق محفوظة عرب تك</p>
    </footer>
  </body>
</html>
